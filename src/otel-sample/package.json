{
  "name": "functions-quickstart-typescript-azd-otel",
  "version": "1.0.0",
  "description": "Azure Functions TypeScript app with OpenTelemetry instrumentation",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "clean": "rimraf dist",
    "prestart": "npm run clean && npm run build",
    "start": "func start",
    "test": "echo \"No tests yet...\""
  },
  "dependencies": {
    "@azure/functions": "4.7.0",
    "@azure/functions-opentelemetry-instrumentation": "^0.2.0",
    "@azure/monitor-opentelemetry-exporter": "^1.0.0-beta.32",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.67.0",
    "axios": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "rimraf": "^5.0.0",
    "typescript": "^4.0.0"
  },
  "overrides": {
    "@opentelemetry/sdk-trace-base": "^1.30.1"
  },
  "main": "dist/{index.js,src/functions/*.js}"
}
